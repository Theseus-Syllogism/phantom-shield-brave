{
  "manifest_version": 3,
  "name": "Phantom Shield",
  "version": "0.7.0",
  "description": "Phantom values for fingerprinting surfaces Brave's native farbling does not cover. TLS profile + UA dropdown drives upstream JA3/JA4 via the local mitmproxy bridge.",
  "minimum_chrome_version": "111",
  "update_url": "https://UPDATE_HOST/phantom-shield/update.xml",
  "permissions": ["storage", "activeTab", "declarativeNetRequest", "proxy"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    { "resources": ["profiles.js", "font-presets.js", "bridge-setup.js"], "matches": ["<all_urls>"] }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Phantom Shield"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "match_origin_as_fallback": true,
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN",
      "js": ["lib.js", "font-presets.js", "inject.js"]
    },
    {
      "matches": ["<all_urls>"],
      "match_origin_as_fallback": true,
      "all_frames": true,
      "run_at": "document_start",
      "world": "ISOLATED",
      "js": ["isolated.js"]
    }
  ]
}
