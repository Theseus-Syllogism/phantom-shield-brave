[Unit]
Description=Phantom Shield mitmproxy bridge
After=network.target

[Service]
Type=simple
ExecStart=__INSTALL_DIR__/venv/bin/mitmdump -s __INSTALL_DIR__/addon.py --listen-host 127.0.0.1 --listen-port __PORT__ --set connection_strategy=lazy
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
